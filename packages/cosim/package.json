{
  "name": "@modelscript/cosim",
  "version": "0.0.0",
  "description": "MQTT-linked co-simulation engine for ModelScript",
  "keywords": [
    "modelscript",
    "co-simulation",
    "mqtt",
    "fmi",
    "fmu"
  ],
  "homepage": "https://modelscript.org",
  "bugs": {
    "url": "https://github.com/modelscript/modelscript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/modelscript/modelscript.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Mohamad Omar Nachawati <mnachawa@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "package.json",
    "README.md",
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "npm run clean && npm run lint && tsc",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelscript/core": "*",
    "aedes": "^1.0.2",
    "aedes-server-factory": "^0.2.1",
    "mqtt": "^5.10.0",
    "pg": "^8.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.18.0",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  }
}
