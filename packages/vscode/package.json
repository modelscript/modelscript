{
  "name": "modelscript",
  "displayName": "ModelScript",
  "version": "0.0.3",
  "description": "Modelica language support — syntax highlighting, completions, hover, diagnostics, formatting, and bundled MSL",
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "modelica",
    "simulation",
    "modeling",
    "MSL",
    "systems engineering"
  ],
  "homepage": "https://modelscript.org",
  "bugs": {
    "url": "https://github.com/modelscript/modelscript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/modelscript/modelscript.git",
    "directory": "packages/vscode"
  },
  "license": "AGPL-3.0-or-later",
  "qna": "marketplace",
  "publisher": "modelscript",
  "browser": "./dist/browserClientMain",
  "scripts": {
    "build": "webpack --mode production --devtool hidden-source-map",
    "compile": "webpack",
    "dev": "webpack --watch",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package --no-dependencies",
    "test-web": "npm run compile && vscode-test-web --browserType=chromium --quality stable --commit cfbea10c5ffb233ea9177d34726e6056e89913dc --port 3100 --testRunnerDataDir=$HOME/.vscode-test-web --extensionDevelopmentPath=. ./test-data",
    "watch": "webpack --watch"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "modelscript.chat",
        "fullName": "ModelScript AI",
        "name": "modelscript",
        "description": "Modelica language assistant — ask about models, MSL components, simulation, and diagnostics",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "modelscript.openDiagram",
        "title": "ModelScript: Open Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "modelscript.openDiagramSource",
        "title": "ModelScript: Open Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "modelscript.runSimulation",
        "title": "ModelScript: Run Simulation",
        "icon": "$(play)"
      },
      {
        "command": "modelscript.addToDiagram",
        "title": "ModelScript: Add to Diagram",
        "icon": "$(add)"
      },
      {
        "command": "modelscript.openProjectFile",
        "title": "ModelScript: Open File"
      },
      {
        "command": "modelscript.autoLayout",
        "title": "ModelScript: Auto Layout",
        "icon": "$(wand)"
      }
    ],
    "configuration": [
      {
        "id": "modelscript",
        "title": "ModelScript",
        "properties": {
          "modelscript.trace.server": {
            "type": "string",
            "scope": "window",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "off",
            "description": "Traces the communication between VS Code and the ModelScript language server."
          }
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "modelscript.diagram",
        "displayName": "Modelica Diagram",
        "selector": [
          {
            "filenamePattern": "*.mo"
          }
        ],
        "priority": "default"
      }
    ],
    "grammars": [
      {
        "language": "modelica",
        "scopeName": "source.modelica",
        "path": "./syntaxes/modelica.tmLanguage.json"
      }
    ],
    "languageModelTools": [
      {
        "name": "modelscript_flatten",
        "displayName": "Flatten Modelica Model",
        "modelDescription": "Flatten a Modelica class to its DAE (Differential Algebraic Equation) form. Resolves inheritance and modifications. Input: { name: string }. Returns the flattened equation system as text.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Fully qualified Modelica class name"
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "modelscript_simulate",
        "displayName": "Simulate Modelica Model",
        "modelDescription": "Simulate a Modelica model and return time-series results. Input: { name: string, startTime?: number, stopTime?: number, solver?: string, format?: 'csv'|'json' }.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Fully qualified class name"
            },
            "stopTime": {
              "type": "number",
              "description": "Simulation stop time"
            },
            "solver": {
              "type": "string",
              "enum": [
                "rk4",
                "dopri5",
                "bdf",
                "auto"
              ]
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "modelscript_query",
        "displayName": "Query Modelica Class",
        "modelDescription": "Introspect a Modelica class — returns its kind, description, components with types, and child classes. Input: { name: string }.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Fully qualified class name"
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "modelscript_parse",
        "displayName": "Parse Modelica Code",
        "modelDescription": "Parse inline Modelica source code and check for syntax errors. Input: { code: string }. Returns parsed classes and any syntax errors.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Modelica source code"
            }
          },
          "required": [
            "code"
          ]
        }
      }
    ],
    "languages": [
      {
        "id": "modelica",
        "aliases": [
          "Modelica",
          "modelica"
        ],
        "extensions": [
          ".mo",
          ".mos"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/icon.png",
          "dark": "./images/icon.png"
        }
      },
      {
        "id": "modelica-notebook",
        "aliases": [
          "Modelica Notebook"
        ],
        "extensions": [
          ".monb"
        ],
        "icon": {
          "light": "./images/icon.png",
          "dark": "./images/icon.png"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "modelscript.openDiagram",
          "when": "editorLangId == modelica",
          "group": "navigation"
        },
        {
          "command": "modelscript.runSimulation",
          "when": "editorLangId == modelica",
          "group": "navigation"
        },
        {
          "command": "modelscript.openDiagramSource",
          "when": "activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.autoLayout",
          "when": "activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "modelscript.addToDiagram",
          "when": "view == modelscript.libraryTree && viewItem =~ /^(model|block|connector)$/",
          "group": "inline"
        },
        {
          "command": "modelscript.addToDiagram",
          "when": "view == modelscript.libraryTree && viewItem =~ /^(model|block|connector)$/",
          "group": "navigation"
        }
      ]
    },
    "notebookRenderer": [
      {
        "id": "modelscript-diagram-renderer",
        "displayName": "Modelica Diagram",
        "entrypoint": "./dist/notebookRenderer.js",
        "mimeTypes": [
          "application/x.modelscript-diagram"
        ]
      }
    ],
    "notebooks": [
      {
        "type": "modelscript-notebook",
        "displayName": "Modelica Notebook",
        "selector": [
          {
            "filenamePattern": "*.monb"
          }
        ]
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "modelica",
        "scopes": {
          "keyword": [
            "keyword.other.modelica"
          ]
        }
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "modelscript.projectTree",
          "name": "Modelica Project",
          "visibility": "visible"
        },
        {
          "id": "modelscript.libraryTree",
          "name": "Modelica Libraries",
          "visibility": "visible"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "modelscript.projectTree",
        "contents": "No Modelica files found in the workspace."
      },
      {
        "view": "modelscript.libraryTree",
        "contents": "Open a Modelica file to browse libraries."
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished",
    "onFileSystem:memfs"
  ],
  "dependencies": {
    "@antv/layout": "^0.3.25",
    "@antv/x6": "^3.1.7",
    "@antv/x6-plugin-selection": "^2.2.2",
    "@mlc-ai/web-llm": "*",
    "@modelscript/lsp": "*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-web": "^0.0.80",
    "@vscode/vsce": "^3.7.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.13.0",
    "path-browserify": "^1.0.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0d1b2a",
    "theme": "dark"
  }
}
