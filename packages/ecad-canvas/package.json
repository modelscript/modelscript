{
  "name": "@modelscript/ecad-canvas",
  "version": "0.0.1",
  "description": "Web-native ECAD PCB layout canvas for ModelScript",
  "keywords": [
    "modelscript",
    "ecad",
    "pcb",
    "gerber"
  ],
  "homepage": "https://modelscript.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/modelscript/modelscript.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Mohamad Omar Nachawati <mnachawa@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
