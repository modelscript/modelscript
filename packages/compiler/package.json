{
  "name": "@modelscript/compiler",
  "version": "0.0.18",
  "description": "ModelScript",
  "keywords": [
    "modelscript"
  ],
  "homepage": "https://modelscript.org",
  "bugs": {
    "url": "https://github.com/modelscript/modelscript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/modelscript/modelscript.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "Mohamad Omar Nachawati <mnachawa@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "default": "./dist/resolver.js"
    },
    "./semantic-node": {
      "types": "./dist/semantic-node.d.ts",
      "default": "./dist/semantic-node.js"
    },
    "./semantic-diff": {
      "types": "./dist/semantic-diff.d.ts",
      "default": "./dist/semantic-diff.js"
    },
    "./symbol-indexer": {
      "types": "./dist/symbol-indexer.d.ts",
      "default": "./dist/symbol-indexer.js"
    },
    "./workspace-index": {
      "types": "./dist/workspace-index.d.ts",
      "default": "./dist/workspace-index.js"
    },
    "./line-index": {
      "types": "./dist/line-index.d.ts",
      "default": "./dist/line-index.js"
    },
    "./interner": {
      "types": "./dist/interner.d.ts",
      "default": "./dist/interner.js"
    },
    "./topology": {
      "types": "./dist/topology.d.ts",
      "default": "./dist/topology.js"
    },
    "./lsp-bridge": {
      "types": "./dist/lsp-bridge.d.ts",
      "default": "./dist/lsp-bridge.js"
    },
    "./adapter-registry": {
      "types": "./dist/adapter-registry.d.ts",
      "default": "./dist/adapter-registry.js"
    },
    "./unified-workspace": {
      "types": "./dist/unified-workspace.d.ts",
      "default": "./dist/unified-workspace.js"
    },
    "./verifier": {
      "types": "./dist/verifier.d.ts",
      "default": "./dist/verifier.js"
    },
    "./arena": {
      "types": "./dist/arena.d.ts",
      "default": "./dist/arena.js"
    },
    "./symbol-arena": {
      "types": "./dist/symbol-arena.d.ts",
      "default": "./dist/symbol-arena.js"
    },
    "./dae-arena": {
      "types": "./dist/dae-arena.d.ts",
      "default": "./dist/dae-arena.js"
    },
    "./arena-printer": {
      "types": "./dist/arena-printer.d.ts",
      "default": "./dist/arena-printer.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "modelscript-language": "./dist/cli.js"
  },
  "files": [
    "package.json",
    "README.md",
    "COPYING",
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "npm run clean && npm run lint && tsc",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "NODE_OPTIONS='--max-old-space-size=8192 --expose-gc' npx tsx tests/testsuite-runner.ts",
    "watch": "tsc --watch"
  },
  "lint-staged": {
    "*.ts": "eslint",
    "*.{ts,tsx,js,json,md,yml,css}": "prettier --write"
  },
  "dependencies": {
    "@modelscript/utils": "*",
    "@svgdotjs/svg.js": "^3.2.5",
    "commander": "^11.0.0",
    "helmlab": "^0.11.9",
    "pako": "^2.1.0",
    "pino": "^10.3.1",
    "tree-sitter-cli": "^0.24.7",
    "web-tree-sitter": "^0.24.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.2",
    "dedent-js": "^1.0.1",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-ctrf-json-reporter": "^0.0.10",
    "jiti": "^2.6.1",
    "lerna": "^9.0.0",
    "lint-staged": "^16.4.0",
    "nx": "^22.6.5",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "rimraf": "^6.1.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
