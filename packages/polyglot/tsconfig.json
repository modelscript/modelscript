{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@modelscript/polyglot": ["./src/index.ts"],
      "@modelscript/polyglot/symbol-indexer": ["./src/symbol-indexer.ts"],
      "@modelscript/polyglot/lsp-bridge": ["./src/lsp-bridge.ts"]
    },
    "declaration": true
  },
  "include": ["src/**/*", "examples/**/*", "tests/**/*"]
}
