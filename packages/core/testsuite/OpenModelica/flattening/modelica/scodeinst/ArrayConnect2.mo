// name: ArrayConnect2
// keywords:
// status: correct
//

connector C
  Real e;
  flow Real f;
end C;

model A
  C p;
  C n;
end A;

model ArrayConnect2
  parameter Integer N = 1000;
  A S, R[N], C[N], G;
equation
  connect(S.p, R[1].p);
  connect(S.n, G.p) ;
  connect(C[1].n, G.p) ;

  for i in 1:N-1 loop
    connect(R[i].n, R[i+1].p);
    connect(C[i+1].n, C[i].n);
  end for;

  for i in 1:N loop
    connect(C[i].p, R[i].n);
  end for;
end ArrayConnect2;

