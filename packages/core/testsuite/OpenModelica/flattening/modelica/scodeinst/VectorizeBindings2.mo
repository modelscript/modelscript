// name: VectorizeBindings2
// keywords:
// status: correct
//

model M1
  parameter Real p;
  Real x;
equation
  der(x) = 1;
end M1;

model M2
  M1 m1[10](each p = 2,
            x(each start = 1,
              each fixed = true));
  M1 m11[10,10](each p = 2);
end M2;

model M3
  M2 m2[3];
end M3;

