record R1
  Real x;
  Real y;
end R1;

record R2
  R1 ra;
  R1 rb;
end R2;

model B
  R2 c[10];
end B;

model PrintRecordTypes1
  B[100] b;
equation
  for i in 1:100 loop
    b[i].c[10] = R2(R1(1, 0), R1(i,1));
    b[i].c[1].rb = R1(i,0);
  end for;
end PrintRecordTypes1;

