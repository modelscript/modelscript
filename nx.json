{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": ["@nx/js"],
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/build",
        "{projectRoot}/public",
        "{projectRoot}/src/**/*.js",
        "{projectRoot}/bindings/**/*.o",
        "{projectRoot}/build/**/*.node",
        "{projectRoot}/build/**/*.wasm",
        "{projectRoot}/build/Release/tree_sitter_modelica_binding.node"
      ]
    },
    "test": {
      "cache": true,
      "dependsOn": ["^build", "build"],
      "outputs": ["{projectRoot}/coverage"]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^build"]
    }
  },
  "release": {
    "projects": ["packages/core", "apps/cli", "languages/modelica/tree-sitter-modelica"],
    "version": {
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk",
      "versionActionsOptions": {
        "skipLockFileUpdate": true
      }
    },
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github"
      },
      "projectChangelogs": true
    },
    "git": {
      "commit": true,
      "tag": true
    }
  },
  "analytics": false
}
