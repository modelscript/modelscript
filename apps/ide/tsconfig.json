{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2024",
    "lib": ["ES2024"],
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
