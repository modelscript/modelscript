    "better-sqlite3": "^12.8.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "graphql": "^16.13.0",
    "graphql-http": "^1.22.4",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.1",
    "n3": "^2.0.1",
