.git
.github
.husky
.nx
.prettierignore
.prettierrc.json
.editorconfig
*.db*

# Build artifacts (rebuilt inside container in standalone mode)
node_modules
coverage
ctrf

# Large files not needed in builds
packages/core/testsuite

# Package-specific
packages/morsel/.react-router
packages/api/data

# Exclude all dist/build directories by default...
dist
build

# ...but re-include the ones needed by PREBUILT=true mode
!packages/core/dist
!packages/api/dist
!packages/web/dist
!packages/morsel/build
!packages/ide/dist
!packages/ide/vscode-web
!packages/ide/github-fs/dist
!packages/vscode/dist
