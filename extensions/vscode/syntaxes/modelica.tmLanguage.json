{
  "name": "Modelica",
  "scopeName": "source.modelica",
  "fileTypes": ["mo"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#type-keywords" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "declarations": {
      "patterns": [
        {
          "match": "\\b(class|model|block|connector|record|function|type|enumeration|expandable)\\s+([_a-zA-Z][_a-zA-Z0-9]*)\\b",
          "captures": {
            "1": {
              "name": "storage.type.modelica"
            },
            "2": {
              "name": "support.type.modelica"
            }
          }
        },
        {
          "match": "\\b(package)\\s+([_a-zA-Z][_a-zA-Z0-9]*)\\b",
          "captures": {
            "1": {
              "name": "storage.modifier.modelica"
            },
            "2": {
              "name": "support.type.modelica"
            }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.modelica",
          "match": "//.*$"
        },
        {
          "name": "comment.block.modelica",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.modelica",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.modelica",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.modelica",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.modelica",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.modelica",
          "match": "\\b(if|then|else|elseif|when|elsewhen|while|for|loop|return|break|each)\\b"
        },
        {
          "name": "storage.type.modelica",
          "match": "\\b(class|model|package|shape|block|connector|record|function|type|enumeration|expandable)\\b"
        },
        {
          "name": "storage.modifier.modelica",
          "match": "\\b(parameter|constant|discrete|continuous|partial|protected|public|inner|outer|replaceable|redeclare|final|encapsulated|flow|stream|input|output|pure|impure|import|annotation|end|extends|constrainedby)\\b"
        },
        {
          "name": "constant.language.modelica",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.operator.logical.modelica",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.modelica",
          "match": "\\b(algorithm|connect|der|equation|external|initial|operator|within)\\b"
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "name": "support.type.modelica",
          "match": "\\b(Boolean|Integer|Real|String)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.modelica",
          "match": "(:=|<=|>=|<>|==|\\+|-|\\*|/|\\^|<|>|=)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.modelica",
          "match": "\\b[_a-zA-Z][_a-zA-Z0-9]*(?=\\s*\\()"
        },
        {
          "name": "variable.other.readwrite.modelica",
          "match": "\\b[_a-zA-Z][_a-zA-Z0-9]*(?=\\s*=)"
        },
        {
          "name": "support.type.modelica",
          "match": "\\b[A-Z][_a-zA-Z0-9]*\\b"
        },
        {
          "name": "variable.other.modelica",
          "match": "\\b[_a-z][_a-zA-Z0-9]*\\b"
        },
        {
          "name": "variable.other.quoted.modelica",
          "match": "'[^']*'"
        }
      ]
    }
  }
}
