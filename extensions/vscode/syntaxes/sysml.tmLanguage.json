{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SysML",
  "scopeName": "source.sysml",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#definition-keywords" },
    { "include": "#usage-keywords" },
    { "include": "#modifier-keywords" },
    { "include": "#operators" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sysml",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sysml",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sysml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sysml",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.sysml",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sysml",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sysml",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.sysml",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sysml",
          "match": "\\b(if|else|then|while|for|loop|return|in|out|inout|import|alias|about|accept|after|all|as|assign|assert|assume|at|bind|by|chains|collect|decide|default|defined|dependency|do|doc|done|emit|entry|exhibit|expose|filter|first|flow|fork|frame|from|hastype|intersect|include|istype|join|merge|message|metadata|multiplicity|namespace|nonunique|objective|of|on|ordered|perform|private|protected|public|readonly|redefines|ref|render|rep|require|satisfy|send|snapshot|specializes|stakeholder|subject|subsets|succession|then|timeslice|to|transition|union|until|use|variant|variation|verify|via|when)\\b"
        },
        {
          "name": "constant.language.sysml",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "definition-keywords": {
      "patterns": [
        {
          "name": "keyword.other.definition.sysml",
          "match": "\\b(package|library|standard|part|attribute|port|connection|interface|allocation|action|state|constraint|requirement|concern|case|analysis|verification|use|view|viewpoint|rendering|enumeration|occurrence|item|calculation|metadata|flow)\\s+(?=def\\b)"
        },
        {
          "name": "storage.type.sysml",
          "match": "\\b(def|definition)\\b"
        }
      ]
    },
    "usage-keywords": {
      "patterns": [
        {
          "name": "keyword.other.usage.sysml",
          "match": "\\b(part|attribute|port|connection|interface|allocation|action|state|constraint|requirement|concern|case|analysis|verification|use|view|viewpoint|rendering|enumeration|occurrence|item|calculation|metadata|flow)\\b"
        }
      ]
    },
    "modifier-keywords": {
      "patterns": [
        {
          "name": "storage.modifier.sysml",
          "match": "\\b(abstract|variation|derived|end|readonly|individual|parallel)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.sysml",
          "match": "\\b(and|or|xor|not|implies)\\b"
        },
        {
          "name": "keyword.operator.comparison.sysml",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.arithmetic.sysml",
          "match": "(\\+|-|\\*|/|%|\\*\\*|\\^)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.sysml",
          "match": "\\b(Boolean|Integer|Real|String|Natural|Positive|NaturalNumber)\\b"
        }
      ]
    }
  }
}
