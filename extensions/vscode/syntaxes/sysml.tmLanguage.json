{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SysML",
  "scopeName": "source.sysml",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#definition-declarations" },
    { "include": "#structural-keywords" },
    { "include": "#control-keywords" },
    { "include": "#modifier-keywords" },
    { "include": "#builtin-types" },
    { "include": "#operators" },
    { "include": "#type-annotations" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sysml",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sysml",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sysml",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sysml",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.sysml",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sysml",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sysml",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.sysml",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "definition-declarations": {
      "comment": "Two-word definition keywords like 'part def', 'attribute def', etc.",
      "patterns": [
        {
          "match": "\\b(package|library|standard|part|attribute|port|connection|interface|allocation|action|state|constraint|requirement|concern|case|analysis|verification|use|view|viewpoint|rendering|enumeration|occurrence|item|calculation|metadata|flow)\\s+(def)\\b",
          "captures": {
            "1": { "name": "storage.type.sysml" },
            "2": { "name": "storage.type.sysml" }
          }
        }
      ]
    },
    "structural-keywords": {
      "comment": "Core SysML structural keywords — package, part, attribute, etc.",
      "patterns": [
        {
          "name": "storage.type.sysml",
          "match": "\\b(package|library|standard|part|attribute|port|connection|interface|allocation|action|state|constraint|requirement|concern|case|analysis|verification|use|view|viewpoint|rendering|enumeration|occurrence|item|calculation|metadata|flow|connect)\\b"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.sysml",
          "match": "\\b(if|else|then|while|for|loop|return|import|alias|about|accept|after|all|as|assign|assert|assume|at|bind|by|chains|collect|decide|default|defined|dependency|do|doc|done|emit|entry|exhibit|expose|filter|first|fork|frame|from|hastype|intersect|include|istype|join|merge|message|multiplicity|namespace|nonunique|objective|of|on|ordered|perform|private|protected|public|readonly|redefines|ref|render|rep|require|satisfy|send|snapshot|specializes|stakeholder|subject|subsets|succession|then|timeslice|to|transition|union|until|variant|variation|verify|via|when|in|out|inout)\\b"
        },
        {
          "name": "constant.language.sysml",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "modifier-keywords": {
      "patterns": [
        {
          "name": "storage.modifier.sysml",
          "match": "\\b(abstract|variation|derived|end|readonly|individual|parallel)\\b"
        }
      ]
    },
    "builtin-types": {
      "comment": "SysML built-in and common type names.",
      "patterns": [
        {
          "name": "support.type.sysml",
          "match": "\\b(Boolean|Integer|Real|String|Natural|Positive|NaturalNumber|Number|ScalarValues|Any|Anything|DataValue|Occurrence|Object|Item|Part|Port|Connection|Interface|Allocation|Action|State|Constraint|Requirement|Concern|Case|AnalysisCase|VerificationCase|View|Viewpoint|Rendering|Calculation|Flow)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.sysml",
          "match": "\\b(and|or|xor|not|implies)\\b"
        },
        {
          "name": "keyword.operator.comparison.sysml",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.arithmetic.sysml",
          "match": "(\\+|-|\\*|/|%|\\*\\*|\\^)"
        }
      ]
    },
    "type-annotations": {
      "comment": "Type references after ':' — e.g., 'capacity : Number'",
      "patterns": [
        {
          "match": "(:)\\s*([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.type.sysml" },
            "2": { "name": "entity.name.type.sysml" }
          }
        }
      ]
    },
    "identifiers": {
      "comment": "Names following definition keywords — e.g., 'part def Engine'",
      "patterns": [
        {
          "match": "\\b(def)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.sysml" },
            "2": { "name": "entity.name.type.sysml" }
          }
        }
      ]
    }
  }
}
