{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [["(", ")"]],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "<", "close": ">" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["\"", "\""],
    ["<", ">"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\w+\\s*\\(",
      "end": "^\\s*\\)"
    }
  }
}
