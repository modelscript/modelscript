{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],

    "sourceMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "esModuleInterop": true
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
