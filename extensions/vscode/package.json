{
  "name": "modelscript",
  "displayName": "ModelScript — Modelica for VS Code",
  "version": "0.0.10",
  "description": "Complete Modelica development environment — diagram editing, simulation, scripting, notebooks, and bundled MSL. No external tools required.",
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "modelica",
    "simulation",
    "modeling",
    "MSL",
    "systems engineering"
  ],
  "homepage": "https://modelscript.org",
  "bugs": {
    "url": "https://github.com/modelscript/modelscript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/modelscript/modelscript.git",
    "directory": "extensions/vscode"
  },
  "license": "AGPL-3.0-or-later",
  "qna": "marketplace",
  "publisher": "modelscript",
  "browser": "./dist/browserClientMain",
  "scripts": {
    "prebuild": "echo 'No prebuild needed'",
    "build": "tsx build.ts",
    "clean": "rimraf dist server/dist",
    "compile": "tsx build.ts",
    "dev": "npm run watch",
    "lint": "eslint src",
    "package": "npx @vscode/vsce package --no-dependencies",
    "test-web": "npm run compile && vscode-test-web --browserType=chromium --quality stable --commit cfbea10c5ffb233ea9177d34726e6056e89913dc --port 3100 --testRunnerDataDir=$HOME/.vscode-test-web --extensionDevelopmentPath=. ./test-data",
    "watch": "tsx build.ts --watch"
  },
  "contributes": {
    "breakpoints": [
      {
        "language": "modelica"
      }
    ],
    "commands": [
      {
        "command": "modelscript.openDiagram",
        "title": "ModelScript: Open Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "modelscript.openDiagramSource",
        "title": "ModelScript: Open Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "modelscript.exportShapeToStep",
        "title": "ModelScript: Open 3D Viewer",
        "icon": "$(play-circle)"
      },
      {
        "command": "modelscript.openStepViewer",
        "title": "ModelScript: Open STEP Viewer",
        "icon": "$(play-circle)"
      },
      {
        "command": "modelscript.openGCodeViewer",
        "title": "ModelScript: Open GCode Viewer",
        "icon": "$(play-circle)"
      },
      {
        "command": "modelscript.openCadExample",
        "title": "ModelScript: 3D CAD Polyglot Example",
        "icon": "$(lightbulb)"
      },
      {
        "command": "modelscript.runSimulation",
        "title": "ModelScript: Run Simulation",
        "icon": "$(play)"
      },
      {
        "command": "modelscript.exportFmi2",
        "title": "ModelScript: Export FMI 2.0",
        "icon": "$(package)"
      },
      {
        "command": "modelscript.exportFmi3",
        "title": "ModelScript: Export FMI 3.0",
        "icon": "$(archive)"
      },
      {
        "command": "modelscript.compileWasm",
        "title": "ModelScript: Compile to WebAssembly",
        "icon": "$(circuit-board)"
      },
      {
        "command": "modelscript.runVerification",
        "title": "ModelScript: Run SysML Verification",
        "icon": "$(check-all)"
      },
      {
        "command": "modelscript.addToDiagram",
        "title": "ModelScript: Add to Diagram",
        "icon": "$(add)"
      },
      {
        "command": "modelscript.autoLayout",
        "title": "ModelScript: Auto Layout",
        "icon": "$(wand)"
      },
      {
        "command": "modelscript.flatten",
        "title": "ModelScript: Flatten Model",
        "icon": "$(list-flat)"
      },
      {
        "command": "modelscript.openChat",
        "title": "ModelScript: Open AI Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "modelscript.cosimConnect",
        "title": "ModelScript: Connect to MQTT Broker",
        "icon": "$(plug)"
      },
      {
        "command": "modelscript.cosimDisconnect",
        "title": "ModelScript: Disconnect from MQTT Broker",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "modelscript.cosimStartInfra",
        "title": "ModelScript: Start Local Co-Simulation Infrastructure",
        "icon": "$(server-process)"
      },
      {
        "command": "modelscript.cosimCreateSession",
        "title": "ModelScript: Create Co-Simulation Session",
        "icon": "$(add)"
      },
      {
        "command": "modelscript.cosimPublishModel",
        "title": "ModelScript: Publish Model as Participant",
        "icon": "$(broadcast)"
      },
      {
        "command": "modelscript.cosimOpenLivePlot",
        "title": "ModelScript: Open Live Simulation Plot",
        "icon": "$(graph)"
      },
      {
        "command": "modelscript.cosimRefresh",
        "title": "ModelScript: Refresh Co-Simulation",
        "icon": "$(refresh)"
      },
      {
        "command": "modelscript.showClassHierarchy",
        "title": "ModelScript: Show Class Hierarchy",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "modelscript.analyzeBlt",
        "title": "ModelScript: Analyze Equation System",
        "icon": "$(graph)"
      },
      {
        "command": "modelscript.showComponentTree",
        "title": "ModelScript: Show Component Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "modelscript.openRequirements",
        "title": "ModelScript: Open Requirements Editor",
        "icon": "$(checklist)"
      },
      {
        "command": "modelscript.openVerificationDashboard",
        "title": "ModelScript: Open V&V Dashboard",
        "icon": "$(shield)"
      },
      {
        "command": "modelscript.registry.search",
        "title": "ModelScript: Search Registry",
        "icon": "$(search)"
      },
      {
        "command": "modelscript.registry.refresh",
        "title": "ModelScript: Refresh Registry",
        "icon": "$(refresh)"
      },
      {
        "command": "modelscript.registry.install",
        "title": "Install Package",
        "icon": "$(cloud-download)"
      },
      {
        "command": "modelscript.openRegistry",
        "title": "Open ModelScript Hub Packages",
        "icon": "$(extensions)"
      },
      {
        "command": "modelscript.registry.uninstall",
        "title": "Uninstall Package",
        "icon": "$(trash)"
      },
      {
        "command": "modelscript.scm.generateCommitMessage",
        "title": "Sparkle: Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "modelscript.openCalibration",
        "title": "ModelScript: Open Calibration",
        "icon": "$(beaker)"
      },
      {
        "command": "modelscript.openOptimization",
        "title": "ModelScript: Open Optimization",
        "icon": "$(graph-line)"
      },
      {
        "command": "modelscript.openSurrogateEditor",
        "title": "ModelScript: Open Surrogate Editor",
        "icon": "$(hubot)"
      },
      {
        "command": "modelscript.openUncertainty",
        "title": "ModelScript: Open Uncertainty",
        "icon": "$(pulse)"
      },
      {
        "command": "modelscript.generateMultiBody",
        "title": "ModelScript: Generate Multi-Body Model from STEP",
        "icon": "$(package)"
      },
      {
        "command": "modelscript.owl2.openDiagram",
        "title": "ModelScript: Open OWL2 Ontology Diagram",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "modelscript.owl2.goToDeclaration",
        "title": "ModelScript: Go to OWL2 Declaration",
        "icon": "$(go-to-file)"
      },
      {
        "command": "modelscript.owl2.refreshClassHierarchy",
        "title": "ModelScript: Refresh Class Hierarchy",
        "icon": "$(refresh)"
      },
      {
        "command": "modelscript.owl2.refreshPropertyHierarchy",
        "title": "ModelScript: Refresh Property Hierarchy",
        "icon": "$(refresh)"
      },
      {
        "command": "modelscript.startRepl",
        "title": "ModelScript: Start REPL Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "modelscript.openSimulationView",
        "title": "ModelScript: Open Simulation View",
        "icon": "$(play)"
      },
      {
        "command": "modelscript.migrateMsimToStudy",
        "title": "ModelScript: Migrate .msim to Study",
        "icon": "$(zap)"
      },
      {
        "command": "modelscript.createFeaSetup",
        "title": "ModelScript: Create FEA Study",
        "icon": "$(beaker)"
      },
      {
        "command": "modelscript.createCfdSetup",
        "title": "ModelScript: Create CFD Study",
        "icon": "$(beaker)"
      },
      {
        "command": "modelscript.generateMesh",
        "title": "ModelScript: Generate Mesh",
        "icon": "$(triangle-right)"
      }
    ],
    "configuration": [
      {
        "id": "modelscript",
        "title": "ModelScript",
        "properties": {
          "modelscript.trace.server": {
            "type": "string",
            "scope": "window",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "off",
            "description": "Traces the communication between VS Code and the ModelScript language server."
          },
          "modelscript.cosim.apiUrl": {
            "type": "string",
            "scope": "window",
            "default": "http://127.0.0.1:3000",
            "description": "ModelScript API server URL for co-simulation services."
          },
          "modelscript.cosim.mqttWsUrl": {
            "type": "string",
            "scope": "window",
            "default": "ws://localhost:9001",
            "description": "MQTT broker WebSocket URL for live data streaming."
          },
          "modelscript.registryUrl": {
            "type": "string",
            "scope": "window",
            "default": "http://127.0.0.1:3000",
            "description": "ModelScript package registry URL. Use http://127.0.0.1:3000 for local development."
          },
          "modelscript.library.useApiRegistry": {
            "type": "boolean",
            "scope": "window",
            "default": true,
            "description": "If enabled, standard libraries (MSL, SysML2) are downloaded from the remote API registry. If disabled, they are loaded from local bundled ZIPs."
          }
        }
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "*.fmu": "modelscript.fmuViewer"
      }
    },
    "customEditors": [
      {
        "viewType": "modelscript.diagram",
        "displayName": "Modelica Diagram",
        "selector": [
          {
            "filenamePattern": "*.mo"
          },
          {
            "filenamePattern": "*.sysml"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "modelscript.fmuViewer",
        "displayName": "FMU Viewer",
        "selector": [
          {
            "filenamePattern": "*.fmu"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "modelscript.sspViewer",
        "displayName": "SSP Viewer",
        "selector": [
          {
            "filenamePattern": "*.ssp"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "modelscript.requirementsEditor",
        "displayName": "Requirements Editor",
        "selector": [
          {
            "filenamePattern": "*.sysml"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "modelscript.stepEditor",
        "displayName": "3D CAD Viewer (STEP)",
        "selector": [
          {
            "filenamePattern": "*.step"
          },
          {
            "filenamePattern": "*.stp"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "modelscript.gcodeViewer",
        "displayName": "GCode Viewer",
        "selector": [
          {
            "filenamePattern": "*.gcode"
          },
          {
            "filenamePattern": "*.nc"
          }
        ],
        "priority": "default"
      }
    ],
    "debuggers": [
      {
        "type": "modelscript",
        "label": "ModelScript Simulator",
        "program": "./dist/browserClientMain.js",
        "runtime": "vscode",
        "languages": [
          "modelica"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the Modelica source file.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch.",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "modelscript",
            "request": "launch",
            "name": "Debug ModelScript",
            "program": "${file}",
            "stopOnEntry": true
          }
        ]
      }
    ],
    "grammars": [
      {
        "language": "modelica",
        "scopeName": "source.modelica",
        "path": "./syntaxes/modelica.tmLanguage.json"
      },
      {
        "language": "sysml",
        "scopeName": "source.sysml",
        "path": "./syntaxes/sysml.tmLanguage.json"
      },
      {
        "language": "step",
        "scopeName": "source.step",
        "path": "./syntaxes/step.tmLanguage.json"
      },
      {
        "language": "owl2",
        "scopeName": "source.owl2",
        "path": "./syntaxes/owl2.tmLanguage.json"
      }
    ],
    "keybindings": [
      {
        "command": "modelscript.openChat",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i"
      }
    ],
    "languageModelTools": [
      {
        "name": "modelscript_flatten",
        "displayName": "Flatten Modelica Model",
        "modelDescription": "Flatten a Modelica class to its DAE (Differential Algebraic Equation) form. Resolves inheritance and modifications. Input: { name: string }. Returns the flattened equation system as text.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Fully qualified Modelica class name"
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "modelscript_add_component",
        "displayName": "Add component to Diagram",
        "modelDescription": "Adds a component (model, block, connector) to the currently active diagram. Input: { className: string, classKind?: string }. The language client will handle placing the component.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "className": {
              "type": "string",
              "description": "Fully qualified Modelica class name of the component being added"
            },
            "classKind": {
              "type": "string",
              "description": "The class kind (e.g. 'model', 'block', 'connector')"
            }
          },
          "required": [
            "className"
          ]
        }
      },
      {
        "name": "modelscript_simulate_and_plot",
        "displayName": "Simulate and Plot",
        "modelDescription": "Triggers a simulation and plots the result for the currently active Modelica file.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "modelscript_simulate",
        "displayName": "Simulate Modelica Model",
        "modelDescription": "Simulate a Modelica model and return time-series results. Input: { name: string, startTime?: number, stopTime?: number, solver?: string, format?: 'csv'|'json' }.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Fully qualified class name"
            },
            "stopTime": {
              "type": "number",
              "description": "Simulation stop time"
            },
            "solver": {
              "type": "string",
              "enum": [
                "rk4",
                "dopri5",
                "bdf",
                "auto"
              ]
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "modelscript_query",
        "displayName": "Query Modelica Class",
        "modelDescription": "Introspect a Modelica class — returns its kind, description, components with types, and child classes. Input: { name: string }.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Fully qualified class name"
            }
          },
          "required": [
            "name"
          ]
        }
      },
      {
        "name": "modelscript_parse",
        "displayName": "Parse Modelica Code",
        "modelDescription": "Parse inline Modelica source code and check for syntax errors. Input: { code: string }. Returns parsed classes and any syntax errors.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Modelica source code"
            }
          },
          "required": [
            "code"
          ]
        }
      }
    ],
    "languages": [
      {
        "id": "modelica",
        "aliases": [
          "Modelica",
          "modelica"
        ],
        "extensions": [
          ".mo",
          ".mos"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/modelica.png",
          "dark": "./images/modelica.png"
        }
      },
      {
        "id": "modelica-notebook",
        "aliases": [
          "Modelica Notebook"
        ],
        "extensions": [
          ".monb"
        ],
        "icon": {
          "light": "./images/modelica.png",
          "dark": "./images/modelica.png"
        }
      },
      {
        "id": "sysml",
        "aliases": [
          "SysML",
          "sysml"
        ],
        "extensions": [
          ".sysml"
        ],
        "configuration": "./sysml-language-configuration.json",
        "icon": {
          "light": "./images/sysml.png",
          "dark": "./images/sysml.png"
        }
      },
      {
        "id": "fmu",
        "extensions": [
          ".fmu"
        ],
        "icon": {
          "light": "./images/fmu.png",
          "dark": "./images/fmu.png"
        }
      },
      {
        "id": "step",
        "aliases": [
          "STEP",
          "ISO 10303-21"
        ],
        "extensions": [
          ".step",
          ".stp",
          ".p21"
        ],
        "configuration": "./step-language-configuration.json"
      },
      {
        "id": "owl2",
        "aliases": [
          "OWL2",
          "OWL2 Functional-Style Syntax"
        ],
        "extensions": [
          ".owl",
          ".owl2",
          ".fss"
        ],
        "configuration": "./owl2-language-configuration.json",
        "icon": {
          "light": "./images/modelica.png",
          "dark": "./images/modelica.png"
        }
      },
      {
        "id": "gcode",
        "aliases": [
          "GCode"
        ],
        "extensions": [
          ".gcode",
          ".nc"
        ]
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/markdownPreview.js"
    ],
    "markdown.previewStyles": [
      "./dist/markdownPreview.css"
    ],
    "menus": {
      "editor/title": [
        {
          "command": "modelscript.openDiagram",
          "when": "(editorLangId == modelica || editorLangId == sysml) && activeCustomEditorId != modelscript.diagram && resourceScheme != 'fmu-view'",
          "group": "navigation"
        },
        {
          "command": "modelscript.openDiagramSource",
          "when": "activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.runSimulation",
          "when": "editorLangId == modelica || activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.flatten",
          "when": "editorLangId == modelica || activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.exportFmi2",
          "when": "(editorLangId == modelica && resourceScheme != 'fmu-view') || activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.exportFmi3",
          "when": "(editorLangId == modelica && resourceScheme != 'fmu-view') || activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.exportShapeToStep",
          "when": "(editorLangId == modelica && resourceScheme != 'fmu-view') || activeCustomEditorId == modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.runVerification",
          "when": "editorLangId == sysml && activeCustomEditorId != modelscript.diagram",
          "group": "navigation"
        },
        {
          "command": "modelscript.openRequirements",
          "when": "editorLangId == sysml",
          "group": "navigation"
        },
        {
          "command": "modelscript.openVerificationDashboard",
          "when": "editorLangId == sysml",
          "group": "navigation"
        },
        {
          "command": "modelscript.openStepViewer",
          "when": "editorLangId == step",
          "group": "navigation"
        },
        {
          "command": "modelscript.openGCodeViewer",
          "when": "editorLangId == gcode",
          "group": "navigation"
        },
        {
          "command": "modelscript.owl2.openDiagram",
          "when": "editorLangId == owl2",
          "group": "navigation"
        },
        {
          "command": "modelscript.openSurrogateEditor",
          "when": "editorLangId == modelica && resourceScheme != 'fmu-view'",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "modelscript.openRegistry",
          "when": "view == modelscript.libraryTree",
          "group": "navigation@1"
        },
        {
          "command": "modelscript.registry.uninstall",
          "when": "view == modelscript.libraryTree",
          "group": "navigation@2"
        },
        {
          "command": "modelscript.registry.search",
          "when": "view == modelscript.registryView",
          "group": "navigation@1"
        },
        {
          "command": "modelscript.registry.refresh",
          "when": "view == modelscript.registryView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "modelscript.addToDiagram",
          "when": "view == modelscript.libraryTree && viewItem =~ /^(model|block|connector)$/",
          "group": "inline"
        },
        {
          "command": "modelscript.addToDiagram",
          "when": "view == modelscript.libraryTree && viewItem =~ /^(model|block|connector)$/",
          "group": "navigation"
        },
        {
          "command": "modelscript.addToDiagram",
          "when": "view == modelscript.mqttTree && viewItem == mqttParticipant",
          "group": "inline"
        },
        {
          "command": "modelscript.addToDiagram",
          "when": "view == modelscript.mqttTree && viewItem == mqttParticipant",
          "group": "navigation"
        },
        {
          "command": "modelscript.registry.install",
          "when": "view == modelscript.registryView && viewItem == registry-package",
          "group": "inline"
        },
        {
          "command": "modelscript.registry.uninstall",
          "when": "view == modelscript.registryView && viewItem == installed-package",
          "group": "inline"
        },
        {
          "command": "modelscript.registry.uninstall",
          "when": "view == modelscript.libraryTree && viewItem == package",
          "group": "inline"
        }
      ],
      "scm/title": [
        {
          "command": "modelscript.scm.generateCommitMessage",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "modelscript.createFeaSetup",
          "when": "resourceExtname == .step || resourceExtname == .stp",
          "group": "modelscript@1"
        },
        {
          "command": "modelscript.createCfdSetup",
          "when": "resourceExtname == .step || resourceExtname == .stp",
          "group": "modelscript@2"
        },
        {
          "command": "modelscript.generateMesh",
          "when": "resourceExtname == .step || resourceExtname == .stp || resourceExtname == .msim",
          "group": "modelscript@3"
        }
      ]
    },
    "notebookRenderer": [
      {
        "id": "modelscript-diagram-renderer",
        "displayName": "Modelica Diagram",
        "entrypoint": "./dist/notebookRenderer.js",
        "mimeTypes": [
          "application/x.modelscript-diagram"
        ]
      }
    ],
    "notebooks": [
      {
        "type": "modelscript-notebook",
        "displayName": "Modelica Notebook",
        "selector": [
          {
            "filenamePattern": "*.monb"
          }
        ]
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "modelica",
