{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "csv",
  "rules": {
    "SourceFile": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "rows",
          "content": {
            "type": "SYMBOL",
            "name": "Row"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_newline"
              },
              {
                "type": "FIELD",
                "name": "rows",
                "content": {
                  "type": "SYMBOL",
                  "name": "Row"
                }
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_newline"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "Row": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "cells",
              "content": {
                "type": "SYMBOL",
                "name": "Cell"
              }
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_delimiter"
                  },
                  {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "FIELD",
                        "name": "cells",
                        "content": {
                          "type": "SYMBOL",
                          "name": "Cell"
                        }
                      },
                      {
                        "type": "BLANK"
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_delimiter"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_delimiter"
                  },
                  {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "FIELD",
                        "name": "cells",
                        "content": {
                          "type": "SYMBOL",
                          "name": "Cell"
                        }
                      },
                      {
                        "type": "BLANK"
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    "Cell": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_quoted_cell"
        },
        {
          "type": "SYMBOL",
          "name": "_unquoted_cell"
        }
      ]
    },
    "_quoted_cell": {
      "type": "PATTERN",
      "value": "\"([^\"]|\"\")*\""
    },
    "_unquoted_cell": {
      "type": "PATTERN",
      "value": "[^,\\r\\n\\t;\"]+"
    },
    "_delimiter": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "STRING",
          "value": ";"
        },
        {
          "type": "STRING",
          "value": "\t"
        }
      ]
    },
    "_newline": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "\r\n"
        },
        {
          "type": "STRING",
          "value": "\n"
        },
        {
          "type": "STRING",
          "value": "\r"
        }
      ]
    },
    "CSVVirtualComponent": {
      "type": "STRING",
      "value": "CSVVirtualComponent"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}
