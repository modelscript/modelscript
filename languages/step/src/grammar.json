{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "step",
  "rules": {
    "StepFile": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "header",
          "content": {
            "type": "SYMBOL",
            "name": "HeaderSection"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "dataSection",
            "content": {
              "type": "SYMBOL",
              "name": "DataSection"
            }
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "trailer",
              "content": {
                "type": "SYMBOL",
                "name": "Trailer"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "Trailer": {
      "type": "STRING",
      "value": "END-ISO-10303-21;"
    },
    "HeaderSection": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "ISO-10303-21;"
        },
        {
          "type": "STRING",
          "value": "HEADER;"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "headerEntity",
            "content": {
              "type": "SYMBOL",
              "name": "HeaderEntity"
            }
          }
        },
        {
          "type": "STRING",
          "value": "ENDSEC;"
        }
      ]
    },
    "HeaderEntity": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "SYMBOL",
            "name": "KEYWORD"
          }
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "ParameterList"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        },
        {
          "type": "STRING",
          "value": ";"
        }
      ]
    },
    "DataSection": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "DATA"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "("
                },
                {
                  "type": "FIELD",
                  "name": "scopeName",
                  "content": {
                    "type": "SYMBOL",
                    "name": "STRING"
                  }
                },
                {
                  "type": "STRING",
                  "value": ")"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ";"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "entity",
            "content": {
              "type": "SYMBOL",
              "name": "EntityInstance"
            }
          }
        },
        {
          "type": "STRING",
          "value": "ENDSEC;"
        }
      ]
    },
    "EntityInstance": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "id",
          "content": {
            "type": "SYMBOL",
            "name": "ENTITY_INSTANCE_NAME"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "record",
          "content": {
            "type": "SYMBOL",
            "name": "_Record"
          }
        },
        {
          "type": "STRING",
          "value": ";"
        }
      ]
    },
    "_Record": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "SimpleRecord"
        },
        {
          "type": "SYMBOL",
          "name": "ComplexRecord"
        }
      ]
    },
    "SimpleRecord": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "SYMBOL",
            "name": "KEYWORD"
          }
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "parameters",
              "content": {
                "type": "SYMBOL",
                "name": "ParameterList"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "ComplexRecord": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "SimpleRecord"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "ParameterList": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_Parameter"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "_Parameter"
              }
            ]
          }
        }
      ]
    },
    "_Parameter": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "TypedParameter"
        },
        {
          "type": "SYMBOL",
          "name": "EntityReference"
        },
        {
          "type": "SYMBOL",
          "name": "REAL"
        },
        {
          "type": "SYMBOL",
          "name": "INTEGER"
        },
        {
          "type": "SYMBOL",
          "name": "STRING"
        },
        {
          "type": "SYMBOL",
          "name": "ENUMERATION"
        },
        {
          "type": "SYMBOL",
          "name": "ListValue"
        },
        {
          "type": "SYMBOL",
          "name": "OMITTED_PARAMETER"
        },
        {
          "type": "SYMBOL",
          "name": "DERIVED_PARAMETER"
        }
      ]
    },
    "EntityReference": {
      "type": "FIELD",
      "name": "target",
      "content": {
        "type": "SYMBOL",
        "name": "ENTITY_INSTANCE_NAME"
      }
    },
    "TypedParameter": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "SYMBOL",
            "name": "KEYWORD"
          }
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "parameters",
              "content": {
                "type": "SYMBOL",
                "name": "ParameterList"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "ListValue": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "ParameterList"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "OMITTED_PARAMETER": {
      "type": "STRING",
      "value": "$"
    },
    "DERIVED_PARAMETER": {
      "type": "STRING",
      "value": "*"
    },
    "ENTITY_INSTANCE_NAME": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[0-9]+"
          }
        ]
      }
    },
    "KEYWORD": {
      "type": "PATTERN",
      "value": "[A-Z][A-Z0-9_]*"
    },
    "INTEGER": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "STRING",
                    "value": "+"
                  },
                  {
                    "type": "STRING",
                    "value": "-"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "[0-9]+"
          }
        ]
      }
    },
    "REAL": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "STRING",
                    "value": "+"
                  },
                  {
                    "type": "STRING",
                    "value": "-"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "[0-9]+"
          },
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[0-9]+"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "STRING",
                        "value": "E"
                      },
                      {
                        "type": "STRING",
                        "value": "e"
                      }
                    ]
                  },
                  {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "CHOICE",
                        "members": [
                          {
                            "type": "STRING",
                            "value": "+"
                          },
                          {
                            "type": "STRING",
                            "value": "-"
                          }
                        ]
                      },
                      {
                        "type": "BLANK"
                      }
                    ]
                  },
                  {
                    "type": "PATTERN",
                    "value": "[0-9]+"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "STRING": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "'"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^']"
                },
                {
                  "type": "STRING",
                  "value": "''"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "'"
          }
        ]
      }
    },
    "ENUMERATION": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "PATTERN",
            "value": "[A-Z][A-Z0-9_]*"
          },
          {
            "type": "STRING",
            "value": "."
          }
        ]
      }
    },
    "BLOCK_COMMENT": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*"
          },
          {
            "type": "PATTERN",
            "value": "[^*]*\\*+([^/*][^*]*\\*+)*"
          },
          {
            "type": "STRING",
            "value": "/"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "BLOCK_COMMENT"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}
