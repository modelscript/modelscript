{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "incremental": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "module": "nodenext",
    "target": "esnext",
    "lib": ["esnext", "DOM"],
    "declaration": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleResolution": "nodenext",
    "types": ["node"]
  },
  "include": ["*.ts", "src-gen/**/*.ts"]
}
