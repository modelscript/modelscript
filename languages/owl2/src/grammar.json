      "type": "PATTERN",
      "value": "[a-zA-Z][a-zA-Z0-9_]*:"
    },
    "FullIRI": {
      "type": "PATTERN",
      "value": "<[^>]*>"
    },
    "AbbreviatedIRI": {
      "type": "PATTERN",
      "value": "[a-zA-Z][a-zA-Z0-9_]*:[a-zA-Z0-9_]+"
