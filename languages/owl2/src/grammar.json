          "name": "AbbreviatedIRI"
        }
      ]
    },
    "IDENT": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "StringLiteral": {
      "type": "PATTERN",
      "value": "\"[^\"]*\""
